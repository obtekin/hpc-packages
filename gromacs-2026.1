module load conda3/latest
module load gcc/12.5
module load cmake
module load cuda/12.9.1

wget https://ftp.gromacs.org/gromacs/gromacs-2026.1.tar.gz
tar xvf gromacs-2026.1.tar.gz
cd gromacs-2026.1
mkdir build
cd build
# gromacs with external mpi
cmake .. -DGMX_BUILD_OWN_FFTW=ON -DREGRESSIONTEST_DOWNLOAD=ON -DCMAKE_INSTALL_PREFIX=/opt/ohpc/pub/apps/gromacs/2026.1/ -DCMAKE_C_COMPILER=mpicc -DCMAKE_CXX_COMPILER=mpicxx -DGMX_GPU=CUDA -DGMX_MPI=on -DGMX_SIMD=AVX_512 -DGMX_OPENMP=ON
